# ============ NORA — environment ============
# Salin ke .env lalu sesuaikan. JANGAN commit .env.

# --- Postgres (state: user, topik, sesi, history) ---
POSTGRES_USER=nora
POSTGRES_PASSWORD=nora_change_me
POSTGRES_DB=nora

# --- Backend (FastAPI) ---
# DATABASE_URL dipakai backend; host 'postgres' = nama service di compose.
DATABASE_URL=postgresql+psycopg://nora:nora_change_me@postgres:5432/nora
# Ganti SECRET_KEY di produksi! (mis. `openssl rand -hex 32`)
SECRET_KEY=nora-dev-secret-change-me
# Origin frontend yang diizinkan (CORS). Pisah koma.
NORA_CORS_ORIGINS=http://localhost:3030

# --- LLM / embedding via 9router (di host RPi5) ---
# host.docker.internal = host dari dalam container (extra_hosts di compose).
NORA_ROUTER_URL=http://host.docker.internal:20128/v1
NORA_ROUTER_KEY=sk-local
NORA_GEN_MODEL=cc/claude-opus-4-8
NORA_VERIFY_MODEL=cc/claude-sonnet-4-6
NORA_EMBED_MODEL=gemini/gemini-embedding-001

# --- Vector store (ChromaDB embedded, mount dari host) ---
# Path DI DALAM container; volume map ke ./backend/data/chroma host.
NORA_CHROMA_PATH=/app/data/chroma
NORA_COLLECTION=ts24008

# --- Frontend (Next.js) ---
# URL backend yang diakses BROWSER (bukan dari dalam container) — port host.
NEXT_PUBLIC_API_URL=http://localhost:8010
